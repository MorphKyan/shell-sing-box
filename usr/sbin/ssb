#!/bin/sh

[ -f /usr/libexec/shell-sing-box/common.sh ] && . /usr/libexec/shell-sing-box/common.sh

SHELL_SING_BOX_VERSION_FILE=/usr/libexec/shell-sing-box/VERSION
SHELL_SING_BOX_REPO_BASE=${SHELL_SING_BOX_REPO_BASE:-https://testingcf.jsdelivr.net/gh/MorphKyan/shell-sing-box}
SHELL_SING_BOX_CHANNEL=${SHELL_SING_BOX_CHANNEL:-latest}

get_shell_sing_box_version() {
    if [ -f "$SHELL_SING_BOX_VERSION_FILE" ]; then
        version=$(head -n 1 "$SHELL_SING_BOX_VERSION_FILE" 2>/dev/null)
        [ -n "$version" ] && printf '%s\n' "$version" && return
    fi
    printf '%s\n' "unknown"
}

get_sing_box_version() {
    if [ -x "$SING_BOX_BIN" ]; then
        version=$("$SING_BOX_BIN" version 2>/dev/null | head -n 1)
        [ -n "$version" ] && printf '%s\n' "$version" && return
    fi
    printf '%s\n' "not installed"
}

show_menu() {
    clear
    echo "=========================================="
    echo "          Shell-Sing-Box 管理面板         "
    echo "=========================================="
    
    # Check status
    if pgrep -f "/etc/sing-box/bin/sing-box run" >/dev/null 2>&1 || pidof sing-box >/dev/null 2>&1; then
        status="\033[32m运行中\033[0m"
    else
        status="\033[31m未运行\033[0m"
    fi
    echo -e " 服务状态: $status"
    echo " Shell-Sing-Box: $(get_shell_sing_box_version)"
    echo " sing-box: $(get_sing_box_version)"
    echo "=========================================="
    echo "  1. 启动/重启服务 (Start/Restart)"
    echo "  2. 停止服务 (Stop)"
    echo "  3. 配置订阅源/配置文件链接"
    echo "  4. 手动更新订阅和规则集"
    echo "  5. 安装/更新本地面板 (Zashboard)"
    echo "  6. 卸载本地面板"
    echo "  7. 设置自动更新定时任务"
    echo "  8. 更新 Shell-Sing-Box 与 sing-box core"
    echo "  9. 完全卸载 Shell-Sing-Box"
    echo "  0. 退出管理面板"
    echo "=========================================="
    read -p " 请输入数字选项 [0-9]: " choice
    echo ""
    
    case "$choice" in
        1)
            echo "正在启动/重启服务..."
            /etc/init.d/shell-sing-box restart
            echo "操作完成。"
            ;;
        2)
            echo "正在停止服务..."
            /etc/init.d/shell-sing-box stop
            echo "服务已停止。"
            ;;
        3)
            echo "当前订阅源链接: ${SUB_URL:-未设置}"
            read -p "请输入新的 sing-box 配置/订阅链接 (留空取消): " input_url
            if [ -n "$input_url" ]; then
                # Remove existing SUB_URL
                if [ -f "$ENV_FILE" ]; then
                    sed -i '/^SUB_URL=/d' "$ENV_FILE"
                else
                    mkdir -p "$(dirname "$ENV_FILE")"
                fi
                echo "SUB_URL=\"$input_url\"" >> "$ENV_FILE"
                
                # reload custom.env
                . "$ENV_FILE"
                echo "订阅源链接已保存。"
                
                read -p "是否立即下载并更新？(y/n): " update_now
                if [ "$update_now" = "y" ] || [ "$update_now" = "Y" ]; then
                    update_sub
                fi
            else
                echo "操作已取消。"
            fi
            ;;
        4)
            update_sub
            ;;
        5)
            echo "正在安装/更新本地面板..."
            /usr/libexec/shell-sing-box/task.sh update-dashboard
            ;;
        6)
            echo "正在卸载本地面板..."
            /usr/libexec/shell-sing-box/dashboard.sh uninstall
            echo "操作完成。"
            ;;
        7)
            set_cron
            ;;
        8)
            upgrade_shell_sing_box
            ;;
        9)
            uninstall_all
            ;;
        0)
            echo "退出面板。"
            exit 0
            ;;
        *)
            echo "输入无效，请重新输入。"
            ;;
    esac
    
    echo ""
    read -p "按回车键返回主菜单..."
    show_menu
}

update_sub() {
    [ -f "$ENV_FILE" ] && . "$ENV_FILE"
    if [ -n "$SUB_URL" ]; then
        echo "正在从订阅源下载配置..."
        mkdir -p "$(dirname "$CONFIG_SOURCE_FILE")"
        if download "$CONFIG_SOURCE_FILE" "$SUB_URL"; then
            echo "配置下载成功！"
            echo "正在重载配置和规则集..."
            /usr/libexec/shell-sing-box/task.sh update-srs
            echo "更新完成！"
        else
            echo "配置下载失败，请检查网络或链接。"
        fi
    else
        echo "未配置订阅源链接，请先在菜单 [3] 中进行配置。"
    fi
}

upgrade_shell_sing_box() {
    [ -f "$ENV_FILE" ] && . "$ENV_FILE"

    if ! command -v download >/dev/null 2>&1; then
        echo "更新失败: 缺少 /usr/libexec/shell-sing-box/common.sh 或 download 函数"
        return 1
    fi

    repo_base=${SHELL_SING_BOX_REPO_BASE:-https://testingcf.jsdelivr.net/gh/MorphKyan/shell-sing-box}
    channel=${SHELL_SING_BOX_CHANNEL:-latest}
    repo="${repo_base%/}@${channel}"
    tmp="${RUNTIME_DIR:-/tmp/shell-sing-box}/upgrade.$$"
    files="README.md README_CN.md install.sh etc/init.d/shell-sing-box etc/sing-box/custom.env etc/sing-box/fake_ip_filter.list usr/libexec/shell-sing-box/VERSION usr/libexec/shell-sing-box/common.sh usr/libexec/shell-sing-box/core-install.sh usr/libexec/shell-sing-box/dashboard.sh usr/libexec/shell-sing-box/firewall.sh usr/libexec/shell-sing-box/generate-system-config.sh usr/libexec/shell-sing-box/prepare.sh usr/libexec/shell-sing-box/srs-update.sh usr/libexec/shell-sing-box/task.sh usr/sbin/ssb"

    rm -rf "$tmp"
    mkdir -p "$tmp"

    echo "正在从 jsDelivr 获取最新 Shell-Sing-Box..."
    echo "更新源: $repo"

    if ! download "$tmp/usr/libexec/shell-sing-box/VERSION" "$repo/usr/libexec/shell-sing-box/VERSION"; then
        echo "更新失败: 无法下载 VERSION"
        rm -rf "$tmp"
        return 1
    fi

    remote_version=$(head -n 1 "$tmp/usr/libexec/shell-sing-box/VERSION" 2>/dev/null)
    echo "当前版本: $(get_shell_sing_box_version)"
    echo "远端版本: ${remote_version:-unknown}"

    for file in $files; do
        printf "下载 %s... " "$file"
        if download "$tmp/$file" "$repo/$file"; then
            echo "完成"
        else
            echo "失败"
            echo "更新失败: 无法下载 $file"
            rm -rf "$tmp"
            return 1
        fi
    done

    for required in \
        usr/libexec/shell-sing-box/common.sh \
        usr/sbin/ssb \
        install.sh \
        usr/libexec/shell-sing-box/VERSION
    do
        if [ ! -f "$tmp/$required" ]; then
            echo "更新失败: 缺少关键文件 $required"
            rm -rf "$tmp"
            return 1
        fi
    done

    echo "正在安装 Shell-Sing-Box 文件..."
    mkdir -p /usr/libexec/shell-sing-box /usr/sbin /etc/init.d /etc/sing-box /usr/share/doc/shell-sing-box
    cp -f "$tmp"/usr/libexec/shell-sing-box/*.sh /usr/libexec/shell-sing-box/
    cp -f "$tmp/usr/libexec/shell-sing-box/VERSION" "$SHELL_SING_BOX_VERSION_FILE"
    cp -f "$tmp/usr/sbin/ssb" /usr/sbin/ssb
    cp -f "$tmp/etc/init.d/shell-sing-box" /etc/init.d/shell-sing-box
    [ -f "$tmp/README.md" ] && cp -f "$tmp/README.md" /usr/share/doc/shell-sing-box/README.md
    [ -f "$tmp/README_CN.md" ] && cp -f "$tmp/README_CN.md" /usr/share/doc/shell-sing-box/README_CN.md

    if [ -f "$tmp/etc/sing-box/custom.env" ]; then
        if [ -f /etc/sing-box/custom.env ]; then
            cp -f "$tmp/etc/sing-box/custom.env" /etc/sing-box/custom.env.default
        else
            cp -f "$tmp/etc/sing-box/custom.env" /etc/sing-box/custom.env
        fi
    fi

    if [ -f "$tmp/etc/sing-box/fake_ip_filter.list" ]; then
        if [ -f /etc/sing-box/fake_ip_filter.list ]; then
            cp -f "$tmp/etc/sing-box/fake_ip_filter.list" /etc/sing-box/fake_ip_filter.list.default
        else
            cp -f "$tmp/etc/sing-box/fake_ip_filter.list" /etc/sing-box/fake_ip_filter.list
        fi
    fi

    chmod 755 /etc/init.d/shell-sing-box
    chmod 755 /usr/libexec/shell-sing-box/*.sh
    chmod 755 /usr/sbin/ssb

    echo "正在更新 sing-box core..."
    if ! /usr/libexec/shell-sing-box/core-install.sh; then
        echo "Shell-Sing-Box 文件已更新，但 sing-box core 更新失败。"
        rm -rf "$tmp"
        return 1
    fi

    rm -rf "$tmp"
    echo "更新完成。"
    echo "Shell-Sing-Box: $(get_shell_sing_box_version)"
    echo "sing-box: $(get_sing_box_version)"

    read -p "是否立即重启 shell-sing-box？(y/n): " restart_now
    if [ "$restart_now" = "y" ] || [ "$restart_now" = "Y" ]; then
        /etc/init.d/shell-sing-box restart
    else
        echo "已跳过重启。"
    fi
}

set_cron() {
    echo "=========================================="
    echo "               定时任务设置               "
    echo "=========================================="
    echo "  1. 每天凌晨 4 点自动更新订阅和规则"
    echo "  2. 每周一凌晨 4 点自动更新订阅和规则"
    echo "  3. 清除所有相关定时任务"
    echo "  0. 返回主菜单"
    echo "=========================================="
    read -p " 请选择 [0-3]: " cron_choice
    
    case "$cron_choice" in
        1)
            sed -i '/shell-sing-box\/task.sh update-srs/d' /etc/crontabs/root 2>/dev/null || true
            echo "0 4 * * * /usr/libexec/shell-sing-box/task.sh update-srs >/dev/null 2>&1" >> /etc/crontabs/root
            /etc/init.d/cron restart 2>/dev/null || true
            echo "定时任务已设置为每天凌晨 4 点。"
            ;;
        2)
            sed -i '/shell-sing-box\/task.sh update-srs/d' /etc/crontabs/root 2>/dev/null || true
            echo "0 4 * * 1 /usr/libexec/shell-sing-box/task.sh update-srs >/dev/null 2>&1" >> /etc/crontabs/root
            /etc/init.d/cron restart 2>/dev/null || true
            echo "定时任务已设置为每周一凌晨 4 点。"
            ;;
        3)
            sed -i '/shell-sing-box\/task.sh update-srs/d' /etc/crontabs/root 2>/dev/null || true
            /etc/init.d/cron restart 2>/dev/null || true
            echo "已清除所有相关的定时任务。"
            ;;
        0)
            return
            ;;
        *)
            echo "输入无效。"
            ;;
    esac
}

uninstall_all() {
    read -p "警告: 此操作将完全卸载 Shell-Sing-Box 并删除所有配置。是否确认？(y/n): " confirm
    if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
        echo "正在停止服务..."
        /etc/init.d/shell-sing-box stop 2>/dev/null || true
        /etc/init.d/shell-sing-box disable 2>/dev/null || true
        
        echo "正在清理文件和目录..."
        rm -rf /usr/libexec/shell-sing-box
        rm -rf /etc/sing-box
        rm -rf /tmp/shell-sing-box
        rm -f /etc/init.d/shell-sing-box
        rm -f /usr/sbin/ssb
        rm -f /usr/bin/ssb
        
        echo "正在清理定时任务..."
        sed -i '/shell-sing-box/d' /etc/crontabs/root 2>/dev/null || true
        /etc/init.d/cron restart 2>/dev/null || true
        
        echo "卸载完成！"
        exit 0
    fi
}

# Main
if [ -n "$1" ]; then
    case "$1" in
        start) /etc/init.d/shell-sing-box start ;;
        stop) /etc/init.d/shell-sing-box stop ;;
        restart) /etc/init.d/shell-sing-box restart ;;
        update) update_sub ;;
        upgrade) upgrade_shell_sing_box ;;
        install) /usr/libexec/shell-sing-box/task.sh update-dashboard ;;
        uninstall-ui) /usr/libexec/shell-sing-box/dashboard.sh uninstall ;;
        *) echo "Usage: $0 {start|stop|restart|update|upgrade|install|uninstall-ui|menu}" ;;
    esac
else
    show_menu
fi
