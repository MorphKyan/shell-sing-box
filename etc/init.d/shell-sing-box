#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

ENV_FILE=/etc/sing-box/custom.env
[ -f "$ENV_FILE" ] && . "$ENV_FILE"

SING_BOX_BIN=${SING_BOX_BIN:-/tmp/shell-sing-box/bin/sing-box}
BASE_DIR=${BASE_DIR:-/etc/sing-box}
CONFIG_RUNTIME_DIR=${CONFIG_RUNTIME_DIR:-/tmp/shell-sing-box/config}
SERVICE_USER=${SERVICE_USER:-root}

start_service() {
    /usr/libexec/shell-sing-box/prepare.sh || return 1

    procd_open_instance
    procd_set_param command "$SING_BOX_BIN" run -D "$BASE_DIR" -C "$CONFIG_RUNTIME_DIR"
    procd_set_param user "$SERVICE_USER"
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance

    sleep 2
    /usr/libexec/shell-sing-box/firewall.sh start
}

stop_service() {
    /usr/libexec/shell-sing-box/firewall.sh stop
}

reload_service() {
    restart
}
