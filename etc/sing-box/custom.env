# shell-sing-box runtime settings for ImmortalWrt/OpenWrt.

BASE_DIR=/etc/sing-box
RUNTIME_DIR=/tmp/shell-sing-box
CONFIG_SOURCE_FILE=/etc/sing-box/generated/config.json
CONFIG_RUNTIME_DIR=/tmp/shell-sing-box/config
RULESET_DIR=/etc/sing-box/ruleset
UI_DIR=/etc/sing-box/ui

SING_BOX_BIN=/etc/sing-box/bin/sing-box
SERVICE_USER=root

CORE_VERSION=latest
CORE_ARCH=auto
GITHUB_PROXY_PREFIX=https://gh.llkk.cc/
CORE_DOWNLOAD_PREFIX=https://gh.llkk.cc/
CORE_RELEASE_BASE=https://github.com/SagerNet/sing-box/releases/download

REDIR_PORT=9998
API_PORT=9999
DNS_PORT=1053
API_SECRET=

TUN_NAME=sbtun0
TUN_INET4=28.0.0.1/30
TUN_INET6=fc00::1/126
FAKEIP_INET4=28.0.0.0/8
FAKEIP_INET6=fc00::/16

NFT_TABLE=singbox
FW_MARK=0x2026
ROUTE_TABLE=2026

DNS_DIRECT=223.5.5.5
DNS_PROXY=https://cloudflare-dns.com/dns-query
DNS_RESOLVER=223.5.5.5
CN_RULESET_TAG=cn

MIRROR_PREFIX=https://testingcf.jsdelivr.net/gh/
ZASHBOARD_URL=https://testingcf.jsdelivr.net/gh/Zephyruso/zashboard@gh-pages/dist-cdn-fonts.zip
ZASHBOARD_ORIGIN_URL=https://github.com/Zephyruso/zashboard/archive/refs/heads/gh-pages.zip

ENABLE_IPV6=0
UPDATE_SRS_ON_START=1
UPDATE_DASHBOARD_ON_START=0
